# ==========================
# OMS Environment Variables
# Copy to .env and fill in values
# ==========================

# PostgreSQL
POSTGRES_USER=oms_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oms_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://oms_user:changeme@postgres:5432/oms_db
SECRET_KEY=changeme-replace-with-long-random-string
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shopify (fill in per tenant later)
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# EasyPost (later)
# EASYPOST_API_KEY=
