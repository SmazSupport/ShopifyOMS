*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.css text eol=lf
Dockerfile text eol=lf
.env* text eol=lf
